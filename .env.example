# Pooled connection — used by Prisma Client at runtime (hostname contains -pooler)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# Direct connection — used by Prisma Migrate / CLI (no -pooler)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Used for signing/session hardening (generate a long random string)
SESSION_SECRET="change-me-to-a-long-random-string"
