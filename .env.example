# ─────────────────────────────────────────────
# Database (Neon PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
# Set to "production" on Vercel, "development" locally
NEXT_PUBLIC_ENV="development"

# ─────────────────────────────────────────────
# MoMo Payment Gateway
# Get credentials from: https://business.momo.vn
# Use test credentials for sandbox: https://developers.momo.vn
# ─────────────────────────────────────────────
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
# URL to redirect customer after payment (replace with your actual domain)
MOMO_REDIRECT_URL="https://yourdomain.com/orders/[id]"
# Webhook URL for MoMo IPN callbacks (must be publicly accessible)
MOMO_IPN_URL="https://yourdomain.com/api/webhooks/momo"

# ─────────────────────────────────────────────
# Rate Limiting (Upstash Redis)
# Create a free Redis database at: https://console.upstash.com
# Required for production rate limiting on auth + order endpoints
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
